# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase ----------------------------------------------------------------
# Local: from `supabase status`. Production: from Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose this to the browser. Used for admin operations and seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude) ------------------------------------------------------
# Get from https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# --- Voyage AI (embeddings) --------------------------------------------------
# Get from https://www.voyageai.com → Dashboard → API Keys.
VOYAGE_API_KEY=

# --- LlamaParse (PDF/Word ingestion) -----------------------------------------
# Get from https://cloud.llamaindex.ai → API Keys.
LLAMA_CLOUD_API_KEY=

# --- Inngest (background jobs) -----------------------------------------------
# Get from Inngest dashboard → Apps → <app> → Keys.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
